# hadoop.env
# ==========
# Variables d'environnement partagées entre NameNode et DataNode.
# Ces variables configurent le cluster HDFS pour Marsa Maroc.
#
# Format des clés : CORE_CONF_xxx / HDFS_CONF_xxx
#   Les "__" sont convertis en "." et "_" en "-"
#   Exemple : CORE_CONF_fs_defaultFS → fs.defaultFS dans core-site.xml

# ── core-site.xml ──────────────────────────────────────────────────────────
# Point d'entrée HDFS
CORE_CONF_fs_defaultFS=hdfs://namenode:9000

# Permettre les requêtes web sans authentification (mode dev)
CORE_CONF_hadoop_http_staticuser_user=root

# ── hdfs-site.xml ──────────────────────────────────────────────────────────
# Facteur de réplication (1 seul DataNode en dev)
HDFS_CONF_dfs_replication=1

# Le DataNode annonce son adresse IP hôte (127.0.0.1) aux clients
# pour que PySpark sur Windows puisse se connecter correctement
HDFS_CONF_dfs_datanode_hostname=127.0.0.1

# DataNode : écouter sur toutes les interfaces
HDFS_CONF_dfs_datanode_address=0.0.0.0:9866
HDFS_CONF_dfs_datanode_http_address=0.0.0.0:9864
HDFS_CONF_dfs_datanode_ipc_address=0.0.0.0:9867

# Désactiver la vérification d'enregistrement basée sur le nom d'hôte
HDFS_CONF_dfs_namenode_datanode_registration_ip___hostname___check=false

# Le client utilise l'hostname annoncé par le DataNode (127.0.0.1)
HDFS_CONF_dfs_client_use__datanode__hostname=true

# Durée de la permission temporaire
HDFS_CONF_dfs_namenode_name_dir=file:///hadoop/dfs/name
HDFS_CONF_dfs_datanode_data_dir=file:///hadoop/dfs/data

# ── yarn-site.xml (désactivé — pas besoin pour notre pipeline) ────────────
YARN_CONF_yarn_log___aggregation___enable=true
